# .env.example
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
# All values here are public-safe configuration (no secret keys required).

# ─── Site URLs ───────────────────────────────────────────────────────────────
# The canonical base URL for the deployed site (no trailing slash)
VITE_SITE_URL=https://mokxya.pages.dev

# ─── Pilot Form ──────────────────────────────────────────────────────────────
# Google Forms (or similar free form) URL for the founding pilot application.
# Leave empty until your form is ready — the website gracefully shows contact info instead.
VITE_PILOT_FORM_URL=

# ─── Contact Information ─────────────────────────────────────────────────────
# Public contact details displayed in the footer and Contact section.
VITE_CONTACT_PHONE=
VITE_CONTACT_WHATSAPP=
VITE_CONTACT_EMAIL=
VITE_FOUNDER_NAME=

# ─── Social Media ────────────────────────────────────────────────────────────
# Leave empty for any platform you have not yet set up — links hide automatically.
VITE_SOCIAL_FACEBOOK=
VITE_SOCIAL_TIKTOK=
VITE_SOCIAL_YOUTUBE=
VITE_SOCIAL_INSTAGRAM=
VITE_SOCIAL_LINKEDIN=

# ─── Pricing ─────────────────────────────────────────────────────────────────
# Leave empty until pricing is decided. The website will display "Price TBA".
VITE_PRICING_STARTER=
VITE_PRICING_BUSINESS=

# ─── Environment ─────────────────────────────────────────────────────────────
# Set to "production" when deploying live. Controls analytics and mock-data mode.
VITE_ENVIRONMENT=production
