# .env.example
# ==============================================================================
# PILOT FORM CONFIGURATION
# 
# Note: All VITE_ variables are public in the browser bundle. Do not store secrets here.
# 
# Submission Priority:
# 1. Endpoint Mode: Activates if VITE_PILOT_FORM_URL is a valid http/https URL.
#    (Must support POST JSON CORS requests from the browser)
# 2. WhatsApp Mode: Activates if Endpoint is empty but VITE_WHATSAPP_NUMBER is valid.
# 3. Email Mode: Activates if above are empty but VITE_CONTACT_EMAIL is valid.
# 4. Unavailable Mode: Activates if all are empty ("Applications opening soon").
# ==============================================================================

VITE_PILOT_FORM_URL=
VITE_WHATSAPP_NUMBER=
VITE_CONTACT_EMAIL=

# Optional: Set HTTP method for the endpoint (defaults to POST)
VITE_PILOT_FORM_METHOD=POST

# ─── Site URLs ───────────────────────────────────────────────────────────────
# The canonical base URL for the deployed site (no trailing slash)
VITE_SITE_URL=https://mokxya.pages.dev


# ─── Contact Information ─────────────────────────────────────────────────────
# Public contact details displayed in the footer and Contact section.
VITE_CONTACT_PHONE=
VITE_CONTACT_WHATSAPP=
VITE_CONTACT_EMAIL=
VITE_FOUNDER_NAME=

# ─── Social Media ────────────────────────────────────────────────────────────
# Leave empty for any platform you have not yet set up — links hide automatically.
VITE_SOCIAL_FACEBOOK=
VITE_SOCIAL_TIKTOK=
VITE_SOCIAL_YOUTUBE=
VITE_SOCIAL_INSTAGRAM=
VITE_SOCIAL_LINKEDIN=

# ─── Pricing ─────────────────────────────────────────────────────────────────
# Leave empty until pricing is decided. The website will display "Price TBA".
VITE_PRICING_STARTER=
VITE_PRICING_BUSINESS=

# ─── Environment ─────────────────────────────────────────────────────────────
# Set to "production" when deploying live. Controls analytics and mock-data mode.
VITE_ENVIRONMENT=production
